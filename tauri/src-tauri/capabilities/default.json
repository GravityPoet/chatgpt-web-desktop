{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for remote ChatGPT pages. Only download and zoom bridge commands are callable from the webview.",
  "windows": ["main", "auth-*", "incognito-*"],
  "remote": {
    "urls": [
      "https://chatgpt.com/*",
      "https://*.chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://*.chat.openai.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-set-native-webview-zoom",
    "allow-start-blob-download",
    "allow-append-blob-download",
    "allow-finish-blob-download",
    "allow-cancel-blob-download"
  ]
}

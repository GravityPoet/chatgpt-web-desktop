{
  "manifest_version": 3,
  "name": "ChatGPT Cloak Companion",
  "version": "1.1.0",
  "description": "Match the browser timezone to your IP/proxy, removing the timezone-vs-IP mismatch fingerprint signal. Pick a zone or auto-match the current IP.",
  "permissions": ["storage", "scripting", "webNavigation", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "ISOLATED",
      "js": ["seed.js"]
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["spoof.js", "apply.js"]
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Cloak Timezone" }
}

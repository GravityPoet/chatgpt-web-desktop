{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cloak Picker",
  "version": "0.1.0",
  "identifier": "local.cloak.picker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cloak Picker",
        "width": 920,
        "height": 620,
        "minWidth": 760,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../packaging/icon-cloak-picker.icns"]
  }
}
